# Copy this file to `.env` and adjust values for your environment:
#   cp .env.example .env
#
# `.env` is git-ignored. Never commit real secrets.

# Domain and stack identity
DOMAIN=localhost
PROJECT_NAME="FastAPI Refine Starterkit"
STACK_NAME=fastapi-refine-starterkit

# Frontend host used by backend CORS
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
# Generate a strong key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Email. Local Docker Compose overrides these to use MailCatcher.
SMTP_TLS=true
SMTP_SSL=false
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=

SENTRY_DSN=

# S3 / MinIO (local dev uses the bundled MinIO container)
S3_INTERNAL_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=app-assets
S3_ADDRESSING_STYLE=path
S3_PRESIGNED_UPLOAD_EXPIRES_SECONDS=900
S3_PRESIGNED_DOWNLOAD_EXPIRES_SECONDS=900

# Docker image names used by docker-compose.yml
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
TAG=latest

# Optional Traefik dashboard variables for docker-compose.traefik.yml
USERNAME=admin
HASHED_PASSWORD=
EMAIL=admin@example.com
